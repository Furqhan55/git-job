pipeline {
    agent any

    stages {
        stage('Step 1 - Info') {
            steps {
                sh 'echo "Hello Furqhan 🚀"'
                sh 'date'
                sh 'whoami'
            }
        }

        stage('Step 2 - List Files') {
            steps {
                sh 'ls -la'
            }
        }
    }
}
